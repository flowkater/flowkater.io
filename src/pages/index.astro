---
import { getCollection } from "astro:content";
import PostHogLayout from "@/layouts/PostHogLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import FeaturedGrid from "@/components/FeaturedGrid.astro";
import CategorySection from "@/components/CategorySection.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getPostsByCategory from "@/utils/getPostsByCategory";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS, CATEGORIES } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);

const categoryPosts = CATEGORIES.map(cat => ({
  category: cat,
  posts: getPostsByCategory(posts, cat.slug),
})).filter(({ posts }) => posts.length > 0);

const pageSummary =
  "창업과 CTO, 그리고 다시 시작하는 프로젝트를 기록하는 공간입니다. 회고와 실험, 기술 노트와 개인적인 배움을 흐트러지지 않게 담아두려 합니다.";
---

<PostHogLayout
  title={`${SITE.title} | Dev retros & notes`}
  description={pageSummary}
  summary={pageSummary}
  ogImage="/desk-og.jpg"
>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Tony Cho
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        15년차 개발자. 스타트업 공동 창업, 대표, 개발자, CTO — 한 바퀴 다 돌았습니다.<br />
        조직을 빌딩하고 부수고, 비즈니스의 흥망성쇠를 몸으로 겪었습니다. 
        지금은 다시 제로에서, 반려자 Ellie와 함께 새로운 프로덕트를 만들고 있습니다. <br />
        게으르지만 일을 잘할 만큼 똑똑합니다. 사람을 좋아해서 팀으로 일하는 걸 좋아하지만, 같은 이유로 멍청해지기도 합니다. <br />
        지나간 시간을 붙들고자 쓰는 회고록과, 문득문득 떠오르는 잡생각들을 여기에 낙서합니다. <br />
      </p>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex flex-col sm:flex-row sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <FeaturedGrid posts={featuredPosts} />
          {categoryPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      categoryPosts.length > 0 && (
        <section id="categories" class="pt-12 pb-6">
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
            {categoryPosts.map(({ category, posts }) => (
              <CategorySection {category} {posts} />
            ))}
          </div>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</PostHogLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
